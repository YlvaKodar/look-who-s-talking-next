// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  email                   String      @unique
  name                    String
  role                    Role        @default(USER)
  meetings                Meeting[]
  createdGroups           Group[]     @relation("GroupCreator")
  clockerInGroups         Group[]     @relation("GroupKlocker")
  @@map("users")
}

model Group {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  creator                 User         @relation("GroupCreator", fields: [creatorId], references: [id])
  creatorId               String       @db.Uuid
  name                    String
  description             String?
  meetings                Meeting[]
  klockers                User[]       @relation("GroupKlocker")
  @@map("groups")
}

model Meeting {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt               DateTime      @default(now())
  creator                 User          @relation(fields: [creatorId], references: [id])
  creatorId               String        @db.Uuid
  group                   Group?        @relation(fields: [groupId], references: [id])
  groupId                 String?       @db.Uuid
  title                   String?
  startedAt               DateTime
  womenCount              Int           @default(0)
  nonbinaryCount          Int           @default(0)
  menCount                Int           @default(0)
  totalSpeakingTime       Int
  womenSpeakingTime       Int
  nonbinarySpeakingTime   Int
  menSpeakingTime         Int
  womenStatementCount     Int
  nonbinaryStatementCount Int
  menStatementCount       Int
  @@map("meetings")
}

enum Role {
  USER
  ADMIN
}